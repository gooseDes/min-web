{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Min Desktopa",
    "version": "0.1.0",
    "identifier": "com.min.desktop",
    "build": {
        "beforeDevCommand": "pnpm --filter web dev",
        "beforeBuildCommand": "pnpm --filter web build",
        "devUrl": "http://localhost:5173",
        "frontendDist": "../../web/dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Min Desktop",
                "width": 800,
                "height": 600
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
        "resources": ["assets/tray.png"],
        "createUpdaterArtifacts": true
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxMUQ2NUM5ODBFRTIwNjkKUldScElPNkF5V1VkZ2RTRTZFVmx5SVBhNVZ3cFRxSUZXQkVMSkJITjAvSnBTRW1ZOHU0aHQ2bE8K",
            "endpoints": ["https://github.com/gooseDes/min-web/releases/latest/download/latest.json"]
        }
    }
}
