{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "core:tray:default",
        "opener:default",
        "notification:default",
        "fs:default",
        "fs:allow-appcache-write",
        "fs:allow-appcache-read",
        {
            "identifier": "fs:scope",
            "allow": ["$APPCONFIG/**/*", "$DOCUMENT/**/*"]
        },
        "http:allow-fetch",
        {
            "identifier": "http:default",
            "allow": [{ "url": "*://*" }, { "url": "*://*:*" }]
        }
    ]
}
